{
  "expo": {
    "name": "바로팀",
    "slug": "QuickTeams",
    "version": "2.1.0",
    "scheme": "quickteams",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": false,
      "bundleIdentifier": "com.quickteams.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6B9BD2"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.quickteams.app"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      "expo-screen-orientation"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "47adb753-80b7-418b-9f02-7387878478a1"
      }
    },
    "owner": "albery97"
  }
}
